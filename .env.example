# ______ Backend _______
FLASK_MODE=development
SECRET_KEY=your-secret-key-here

# Ports
BACKEND_PORT=2222
FRONTEND_PORT=1111
DB_EXPOSED_PORT=5432

# Database
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=OpenW
DB_HOST=db
DB_PORT=5432
SQLALCHEMY_DATABASE_URI=postgresql://postgres:your-db-password@db:5432/OpenW

# Groq AI
GROQ_API_KEY=gsk_...

# WhatsApp Cloud API (Meta)
# App: CiberSeguridad WA | App ID: xxxxxxxxxx
# Token temporal (24h) - regenerar en: developers.facebook.com > CiberSeguridad WA > WhatsApp > Configuración de la API
WHATSAPP_APP_ID=your-app-id
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:2222
